# feeds.conf.default — x86-64 自定义 feeds
# 官方 feeds（保留）
src-git packages https://git.openwrt.org/feed/packages.git
src-git luci https://git.openwrt.org/project/luci.git
src-git routing https://git.openwrt.org/feed/routing.git
src-git telephony https://git.openwrt.org/feed/telephony.git

# ====== 第三方插件源 ======

# lq-wq 综合插件包
src-git lq_wq https://github.com/lq-wq/openwrt-package.git

# kenzok8 常用插件集合
src-git kenzo https://github.com/kenzok8/openwrt-packages

# kenzok8 small 插件（passwall/ssr 等依赖）
src-git small https://github.com/kenzok8/small

# OpenWrt-nikki（原 mihomo）代理内核
src-git nikki https://github.com/nikkinikki-org/OpenWrt-nikki.git;main

# netdata 系统监控
src-git netdata https://github.com/sirpdboy/luci-app-netdata.git

# AdGuardHome 广告过滤（UI + 核心）
src-git adguardhome https://github.com/rufengsuixing/luci-app-adguardhome.git

# OpenClash 代理客户端
src-git openclash https://github.com/vernesong/OpenClash.git
